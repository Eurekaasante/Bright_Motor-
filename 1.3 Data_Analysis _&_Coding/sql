-------------------------
--Extract Dates
------------------------

SELECT 
    
    PARSE_TIMESTAMP('%a %b %d %Y %H:%M:%S', Saledate) AS Cleaned_Timestamp,

   
    FORMAT_TIMESTAMP('%A', PARSE_TIMESTAMP('%a %b %d %Y %H:%M:%S', Saledate)) AS Day_of_week,

   
    EXTRACT(YEAR FROM PARSE_TIMESTAMP('%a %b %d %Y %H:%M:%S', Saledate)) AS Year_of_sale

FROM `uscarsales.salesdata.BMAnalyse_GOLD`;


-------------------------------
--Extract the time
------------------------------
SELECT 
Saledate AS Raw_String,
 
    SAFE.PARSE_TIMESTAMP('%a %b %d %Y %H:%M:%S', Saledate) AS Full_Timestamp,

 
    EXTRACT(HOUR FROM SAFE.PARSE_TIMESTAMP('%a %b %d %Y %H:%M:%S', Saledate)) AS Sale_Hour,

  
    EXTRACT(MINUTE FROM SAFE.PARSE_TIMESTAMP('%a %b %d %Y %H:%M:%S', Saledate)) AS Sale_Minute,

  
    FORMAT_TIMESTAMP('%I:%M %p', SAFE.PARSE_TIMESTAMP('%a %b %d %Y %H:%M:%S', Saledate)) AS Formatted_Time

FROM `uscarsales.salesdata.BMAnalyse_GOLD`
WHERE Saledate IS NOT NULL;


-----------------------------
--Exploring Case Statements
-----------------------------
SELECT Saledate,
CASE 
    WHEN FORMAT_TIMESTAMP('%A', SAFE.PARSE_TIMESTAMP('%a %b %d %Y %H:%M:%S', Saledate)) IN ('Saturday', 'Sunday') THEN 'Weekend'
    ELSE 'Weekday'
END AS Week_Part

FROM `uscarsales.salesdata.BMAnalyse_GOLD`


--time of day

SELECT Saledate,
CASE 
    WHEN EXTRACT(HOUR FROM SAFE.PARSE_TIMESTAMP('%a %b %d %Y %H:%M:%S', Saledate)) BETWEEN 6 AND 11 THEN 'Morning'
    WHEN EXTRACT(HOUR FROM SAFE.PARSE_TIMESTAMP('%a %b %d %Y %H:%M:%S', Saledate)) BETWEEN 12 AND 16 THEN 'Afternoon'
    ELSE 'Evening/Night'
END AS Day_Session
FROM `uscarsales.salesdata.BMAnalyse_GOLD`;


SELECT `YEAR`,

CASE 
    WHEN Year >= 2015 THEN 'Newer Inventory'
    WHEN Year BETWEEN 2010 AND 2014 THEN 'Mid-Age'
    WHEN Year BETWEEN 2000 AND 2009 THEN 'Older Generation'
    ELSE 'Vintage/Classic'
END AS Vehicle_Generation
FROM `uscarsales.salesdata.BMAnalyse_GOLD`;

SELECT `Odometer`,

CASE 
    WHEN Odometer < 30000 THEN 'Low Mileage (Premium)'
    WHEN Odometer BETWEEN 30000 AND 100000 THEN 'Standard Usage'
    WHEN Odometer > 100000 THEN 'High Mileage'
    ELSE 'Unknown Mileage'
END AS Usage_Tier

FROM `uscarsales.salesdata.BMAnalyse_GOLD`;

SELECT `Sellingprice`,

CASE 
    WHEN Sellingprice > 50000 THEN 'Luxury'
    WHEN Sellingprice BETWEEN 20000 AND 50000 THEN 'Mid-Range'
    WHEN Sellingprice < 20000 AND Sellingprice > 0 THEN 'Budget'
    ELSE 'No Price Data'
END AS Price_Segment

FROM `uscarsales.salesdata.BMAnalyse_GOLD`;

SELECT `Sellingprice`, 
        `MMR`,
CASE 
    WHEN Sellingprice > MMR THEN 'Above Market Value'
    WHEN Sellingprice < MMR THEN 'Below Market Value'
    ELSE 'At Market Value'
END AS Market_Position

FROM `uscarsales.salesdata.BMAnalyse_GOLD`;

SELECT state,
CASE 
    WHEN State IN ('WA', 'OR', 'CA', 'NV', 'AZ', 'ID', 'MT', 'WY', 'CO', 'NM', 'UT', 'AK', 'HI') THEN 'West'
    WHEN State IN ('ND', 'SD', 'NE', 'KS', 'MN', 'IA', 'MO', 'WI', 'IL', 'MI', 'IN', 'OH') THEN 'Midwest'
    WHEN State IN ('TX', 'OK', 'AR', 'LA', 'MS', 'AL', 'TN', 'KY', 'WV', 'VA', 'MD', 'DE', 'DC', 'NC', 'SC', 'GA', 'FL') THEN 'South'
    WHEN State IN ('PA', 'NJ', 'NY', 'CT', 'RI', 'MA', 'VT', 'NH', 'ME') THEN 'Northeast'
    ELSE 'Other'
END AS Sales_Region

FROM `uscarsales.salesdata.BMAnalyse_GOLD`;

SELECT state,
CASE 
    WHEN State IN ('MI', 'OH', 'PA', 'NY', 'IL', 'WI', 'MN', 'IN') THEN 'Rust Belt'
    WHEN State IN ('FL', 'AZ', 'TX', 'CA', 'NM', 'NV') THEN 'Sun Belt'
